# Supabase (Public/Vite) — expostos ao browser
VITE_SUPABASE_URL=your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase (Backend) — NÃO expor ao browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude API (Anthropic) — motor de geração de posts
ANTHROPIC_API_KEY=your-anthropic-key

# LinkedIn — cross-post automático (token expira a cada ~60 dias)
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_PERSON_URN=urn:li:person:xxxxxxxx
